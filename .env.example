DEEPAGENT_DEFAULT_MODEL=anthropic:claude-sonnet-4-6

# 通用配置：会作为各 Provider 的兜底配置
# LLM_API_KEY=your_key_here
# LLM_BASE_URL=https://your-llm-endpoint.example.com/v1

# Anthropic
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI / OpenAI-compatible
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# 任何新增 provider 都可按同样规则配置：
# 例如 Groq
# DEEPAGENT_DEFAULT_MODEL=groq:llama-3.3-70b-versatile
# GROQ_API_KEY=your_groq_key_here

# 例如 Google GenAI
# DEEPAGENT_DEFAULT_MODEL=google-genai:gemini-2.5-pro
# GOOGLE_GENAI_API_KEY=your_google_key_here
